class Solution:
    def lengthOfLongestSubstring(self, s: str) -> int:

        # Stores the maximum length of a valid substring found so far
        max_len = 0

        # Choose every index as the starting point of a substring
        for i in range(len(s)):

            # Set to store unique characters in current substring
            seen = set()

            # Extend the substring from index i onwards
            for j in range(i, len(s)):

                # If character already exists,
                # substring is no longer valid
                if s[j] in seen:
                    break

                # Add current character to the set
                seen.add(s[j])

                # Length of current valid substring
                curr_len = j - i + 1

                # Update maximum length
                max_len = max(max_len, curr_len)

        return max_len
